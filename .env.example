# Copier en .env et remplir.  Le .env n'est JAMAIS committé (cf. .gitignore).
#   cp .env.example .env

# --- RAG (panneau Jarvis) ---------------------------------------------------
# Sans clé : réponses en mode "stub" hors-ligne. Avec : réponses rédigées par Claude.
ANTHROPIC_API_KEY=

# --- Tickets Everping -------------------------------------------------------
# Refresh token Firebase (cf. README). Sans : échantillon anonymisé.
EVERPING_REFRESH_TOKEN=
# Optionnel (défaut = Bleu Citron) :
EVERPING_CLIENT_ID=

# --- Supervision Uptime Kuma ------------------------------------------------
UPTIME_KUMA_BASE_URL=https://monit.bleucitron.pg3.xyz
# Option 1 : clé API (endpoint /metrics) — à révoquer/régénérer régulièrement.
UPTIME_KUMA_API_KEY=
# Option 2 : page de statut publique (prioritaire si renseignée).
UPTIME_KUMA_STATUS_SLUG=

# --- Cloudflare Tunnel (exposition publique) --------------------------------
# Jeton du tunnel "remotely-managed" créé dans Cloudflare Zero Trust.
# Utilisé uniquement avec :  docker compose --profile tunnel up -d
TUNNEL_TOKEN=
